# Copy this file to server/.env and fill in your values
PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxx.mongodb.net/?appName=Cluster0
JWT_SECRET=generate_with_node_-e_crypto.randomBytes(64).toString(hex)
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=generate_with_node_-e_crypto.randomBytes(64).toString(hex)

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Gmail SMTP — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# Client URL
CLIENT_URL=http://localhost:5173
